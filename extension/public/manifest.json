{
  "manifest_version": 3,
  "name": "Alexandria AI",
  "version": "1.0.0",
  "description": "Your intelligent learning companion - AI-powered video analysis & smart learning",
  "author": "Your Name",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.vimeo.com/*",
    "https://*.coursera.org/*",
    "https://*.udemy.com/*",
    "https://localhost/*",
    "http://localhost/*"
  ],
  "optional_permissions": [
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Alexandria AI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://*.vimeo.com/*",
        "https://*.coursera.org/*",
        "https://*.udemy.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
