# ======================================
# Alexandria AI Learning Companion - Configuration
# ======================================

# --- Core API ---
GOOGLE_API_KEY=your_google_gemini_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ---- Database ----
DATABASE_URL=sqlite:///./alexandria.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/alexandria

# ---- Authentication ----
SECRET_KEY=alexandria-secret-key-change-in-production-12345
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ---- Multi-language Support ----
# Supported languages: en, es, fr, de, it, pt, ja, zh, ko, ru, ar, hi
DEFAULT_LANGUAGE=en

# ---- Spotify Integration ----
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ---- Notion Integration ----
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ---- Google Drive / Docs Integration (Optional) ----
GOOGLE_DRIVE_CREDENTIALS=path/to/google_credentials.json

# ---- ChromaDB ----
ENABLE_CHROMA=1
CHROMA_DB_PATH=./chroma_db

# ---- Backend Server ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_WORKERS=2

# ---- Frontend ----
VITE_API_BASE=http://localhost:8000
VITE_APP_NAME=Alexandria

# ---- Extension ----
EXTENSION_API_BASE=http://localhost:8000
EXTENSION_VERSION=2.0.0

# ---- Development ----
DEBUG=1
LOG_LEVEL=INFO
